{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://effective-viewport.dev/schemas/constraints.schema.json",
  "title": "Effective Viewport Constraints",
  "type": "object",
  "required": ["schemaVersion", "os", "browser"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "os": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/constraintGroup" }
    },
    "browser": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/constraintGroup" }
    }
  },
  "$defs": {
    "constraintGroup": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "minItems": 1,
        "items": { "$ref": "#/$defs/constraintEntry" }
      }
    },
    "constraintEntry": {
      "type": "object",
      "required": ["measurements"],
      "additionalProperties": false,
      "properties": {
        "appliesTo": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "os": { "enum": ["macos", "windows", "ios", "android", "linux"] },
            "osVersion": { "type": "string" },
            "browserVersion": { "type": "string" }
          }
        },
        "includes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "measurements": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["heightDip", "measuredAt"],
            "additionalProperties": false,
            "properties": {
              "heightDip": { "type": "number", "minimum": 0 },
              "collapsedHeightDip": { "type": "number", "minimum": 0 },
              "bottomHeightDip": { "type": "number", "minimum": 0 },
              "collapsedBottomHeightDip": { "type": "number", "minimum": 0 },
              "measuredAt": { "type": "string", "format": "date-time" },
              "verified": { "type": "boolean" },
              "source": { "type": "string" },
              "notes": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
